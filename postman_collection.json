{
  "info": {
    "name": "Category & Product API",
    "description": "Full API collection for testing Category and Product modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Category",
      "item": [
        {
          "name": "Get Categories (List)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/category?page=1&per_page=20&sort_by=name&sort_order=asc",
              "host": ["{{base_url}}"],
              "path": ["category"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "20"},
                {"key": "search", "value": "", "disabled": true},
                {"key": "search_id", "value": "", "disabled": true},
                {"key": "status", "value": "", "disabled": true},
                {"key": "sort_by", "value": "name"},
                {"key": "sort_order", "value": "asc"}
              ]
            }
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/category/1"
          }
        },
        {
          "name": "Create Category (Root)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/category",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Для мотоцикліста\",\n  \"description\": \"Головна категорія для мотоциклістів\",\n  \"parent_category_id\": 0,\n  \"seo_keyword\": \"dlya-motocyklista\",\n  \"meta_title\": \"Для мотоцикліста\",\n  \"meta_description\": \"Товари для мотоциклістів\",\n  \"meta_keyword\": \"мото, мотоцикліст\",\n  \"status\": 1\n}"
            }
          }
        },
        {
          "name": "Create Category (Child)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/category",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Аксесуари\",\n  \"description\": \"Аксесуари для мотоциклістів\",\n  \"parent_category_id\": 1,\n  \"seo_keyword\": \"aksesuari\",\n  \"status\": 1\n}"
            }
          }
        },
        {
          "name": "Create Category (Grandchild)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/category",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Рюкзаки\",\n  \"description\": \"Рюкзаки для мотоциклістів\",\n  \"parent_category_id\": 2,\n  \"seo_keyword\": \"ryukzaki\",\n  \"status\": 1\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/category/1",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Для мотоцикліста (оновлено)\",\n  \"status\": 0\n}"
            }
          }
        },
        {
          "name": "Delete Category (Recursive)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/category/1"
          }
        },
        {
          "name": "Search Categories by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/category?search=Рюкзаки",
              "host": ["{{base_url}}"],
              "path": ["category"],
              "query": [
                {"key": "search", "value": "Рюкзаки"}
              ]
            }
          }
        },
        {
          "name": "Filter Categories by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/category?status=1",
              "host": ["{{base_url}}"],
              "path": ["category"],
              "query": [
                {"key": "status", "value": "1"}
              ]
            }
          }
        },
        {
          "name": "Sort Categories (Я-А)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/category?sort_by=name&sort_order=desc",
              "host": ["{{base_url}}"],
              "path": ["category"],
              "query": [
                {"key": "sort_by", "value": "name"},
                {"key": "sort_order", "value": "desc"}
              ]
            }
          }
        }
      ]
